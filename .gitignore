# =============================================================================
# Nexus 2.0 — Git Ignore
# =============================================================================

# --- Environment files (contain secrets) ---
.env
*.env
!*.env.example
# Config env files should NOT be committed (use setup-env.sh to deploy)
config/staging/*.env
config/production/*.env
config/development/*.env

# --- .NET ---
bin/
obj/
*.user
*.suo
*.cache
*.dll
*.pdb

# --- Node / Frontend ---
node_modules/
dist/
.vite/

# --- IDE ---
.vs/
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# --- OS ---
Thumbs.db
.seed-state.env
