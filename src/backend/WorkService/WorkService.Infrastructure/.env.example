# WorkService Environment Variables

# Database
DATABASE_CONNECTION_STRING=Host=localhost;Port=5432;Database=nexus_work;Username=postgres;Password=postgres

# Redis
REDIS_CONNECTION_STRING=localhost:6379

# JWT (shared secret with SecurityService)
JWT_SECRET_KEY=your-256-bit-secret-key-here-min-32-chars!!
JWT_ISSUER=NexusPlatform
JWT_AUDIENCE=NexusServices

# Service URLs
PROFILE_SERVICE_BASE_URL=http://localhost:5002
SECURITY_SERVICE_BASE_URL=http://localhost:5001
UTILITY_SERVICE_BASE_URL=http://localhost:5200

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Service Auth (for inter-service calls)
SERVICE_ID=work-service-001
SERVICE_NAME=WorkService
SERVICE_SECRET=your-service-secret-here
