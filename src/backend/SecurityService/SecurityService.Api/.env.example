# =============================================================================
# SecurityService — Template
# =============================================================================

# Database
DATABASE_CONNECTION_STRING=Host=localhost;Port=5432;Database=nexusDb;SearchPath=nexus_security;Username=postgres;Password=pass.123
DATABASE_SCHEMA=nexus_security

# Redis
REDIS_CONNECTION_STRING=localhost:6379

# JWT (shared across all services — issued by SecurityService)
JWT_SECRET_KEY=your-256-bit-secret-key-here-must-be-at-least-32-characters
JWT_ISSUER=SecurityService
JWT_AUDIENCE=NexusPlatform

# Token Expiry
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# Rate Limiting
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
OTP_RATE_LIMIT_MAX=3
OTP_RATE_LIMIT_WINDOW_MINUTES=5

# Account Lockout
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=10
ACCOUNT_LOCKOUT_WINDOW_HOURS=24
ACCOUNT_LOCKOUT_DURATION_MINUTES=60

# OTP
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3

# Service URLs (inter-service communication)
PROFILE_SERVICE_BASE_URL=http://localhost:5002
UTILITY_SERVICE_BASE_URL=http://localhost:5200

# CORS (only frontend origins — backend calls bypass CORS)
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Logging
SEQ_URL=http://localhost:5341

# Service Identity (for service-to-service JWT auth)
SERVICE_ID=SecurityService
SERVICE_NAME=SecurityService
SERVICE_SECRET=your-service-secret-here
