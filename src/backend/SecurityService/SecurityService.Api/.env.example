# =============================================================================
# SecurityService Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# --- Database (PostgreSQL) ---
DATABASE_CONNECTION_STRING=Host=localhost;Port=5432;Database=nexus_security;Username=postgres;Password=postgres

# --- Redis ---
REDIS_CONNECTION_STRING=localhost:6379

# --- JWT ---
JWT_SECRET_KEY=your-secret-key-min-32-characters-long!!
JWT_ISSUER=SecurityService
JWT_AUDIENCE=NexusPlatform

# --- Token Expiry ---
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# --- Rate Limiting ---
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
OTP_RATE_LIMIT_MAX=3
OTP_RATE_LIMIT_WINDOW_MINUTES=5

# --- Account Lockout ---
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=10
ACCOUNT_LOCKOUT_WINDOW_HOURS=24
ACCOUNT_LOCKOUT_DURATION_MINUTES=60

# --- OTP ---
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3

# --- Service URLs ---
PROFILE_SERVICE_BASE_URL=http://localhost:5002
UTILITY_SERVICE_BASE_URL=http://localhost:5200

# --- CORS ---
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5001,http://localhost:5002,http://localhost:5003,http://localhost:5200,http://localhost:5300

# --- Serilog / Seq ---
SEQ_URL=http://localhost:5341

# --- Service-to-Service Auth ---
SERVICE_ID=SecurityService
SERVICE_NAME=SecurityService
SERVICE_SECRET=your-service-secret-here
