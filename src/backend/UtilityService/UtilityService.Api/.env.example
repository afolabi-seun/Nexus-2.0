# =============================================================================
# UtilityService — Template
# =============================================================================

# Database
DATABASE_CONNECTION_STRING=Host=localhost;Port=5432;Database=nexusDb;SearchPath=nexus_utility;Username=postgres;Password=pass.123
DATABASE_SCHEMA=nexus_utility

# Redis
REDIS_CONNECTION_STRING=localhost:6379

# JWT (shared across all services — issued by SecurityService)
JWT_SECRET_KEY=your-256-bit-secret-key-here-must-be-at-least-32-characters
JWT_ISSUER=SecurityService
JWT_AUDIENCE=NexusPlatform

# CORS (only frontend origins — backend calls bypass CORS)
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Logging
SEQ_URL=http://localhost:5341

# Service-specific settings
OUTBOX_POLL_INTERVAL_SECONDS=30
RETENTION_PERIOD_DAYS=90
RETENTION_SCHEDULE_HOUR=2
NOTIFICATION_RETRY_MAX=3
