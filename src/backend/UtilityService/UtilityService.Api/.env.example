# UtilityService Environment Variables

# Required
DATABASE_URL=Host=localhost;Port=5432;Database=nexus_utility;Username=postgres;Password=postgres
REDIS_URL=localhost:6379
JWT_SECRET=your-256-bit-secret-key-here-min-32-chars

# Optional (defaults shown)
JWT_ISSUER=Nexus-2.0
JWT_AUDIENCE=Nexus-2.0

# --- CORS ---
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5001,http://localhost:5002,http://localhost:5003,http://localhost:5200,http://localhost:5300

# --- Serilog / Seq ---
SEQ_URL=http://localhost:5341

# Outbox processing
OUTBOX_POLL_INTERVAL_SECONDS=30

# Retention archival
RETENTION_PERIOD_DAYS=90
RETENTION_SCHEDULE_HOUR=2

# Notification retry
NOTIFICATION_RETRY_MAX=3
