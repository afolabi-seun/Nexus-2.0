# --- Database (PostgreSQL) ---
DATABASE_CONNECTION_STRING=Host=localhost;Port=5432;Database=nexusDb;SearchPath=nexus_utility;Username=postgres;Password=pass.123
DATABASE_SCHEMA=nexus_utility

# --- Redis ---
REDIS_CONNECTION_STRING=localhost:6379

# --- JWT / Authentication ---
JWT_SECRET_KEY=your-256-bit-secret-key-here-min-32-chars
