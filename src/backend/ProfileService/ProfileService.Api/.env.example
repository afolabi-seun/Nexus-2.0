# --- Database (PostgreSQL) ---
DATABASE_CONNECTION_STRING=Host=localhost;Database=nexusDb;SearchPath=nexus_profile;Username=postgres;Password=pass.123
DATABASE_SCHEMA=nexus_profile

# --- Redis ---
REDIS_CONNECTION_STRING=localhost:6379

# --- JWT / Authentication ---
JWT_SECRET_KEY=your-256-bit-secret-key-here-must-be-at-least-32-characters
JWT_ISSUER=SecurityService
JWT_AUDIENCE=NexusPlatform

# --- Service URLs ---
SECURITY_SERVICE_BASE_URL=http://localhost:5001
UTILITY_SERVICE_BASE_URL=http://localhost:5200

# --- CORS ---
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# --- Logging (Serilog / Seq) ---
SEQ_URL=http://localhost:5341

# --- Service-to-Service Auth ---
SERVICE_ID=ProfileService
SERVICE_NAME=ProfileService
SERVICE_SECRET=your-service-secret-here

# --- Service-Specific ---
INVITE_EXPIRY_HOURS=48
INVITE_TOKEN_LENGTH=128
MAX_DEVICES_PER_USER=5
